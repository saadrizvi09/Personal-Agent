# ──────────────────────────────────────────────────────────────────────────
# AI Persona Agent — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# --- Corpus build (GitHub) ---
# A classic or fine-grained PAT with public_repo / read access. Optional for
# public repos, but without it GitHub rate-limits you to 60 requests/hour.
GITHUB_TOKEN=
# Your GitHub handle (the account that owns the repos to ingest).
GITHUB_HANDLE=

# --- Cal.com (booking backend) ---
# API key from Cal.com → Settings → Developer → API Keys.
CAL_API_KEY=
# The numeric event type id for your interview slot (Cal.com → Event Types →
# open the event → the id is in the URL, e.g. .../event-types/123456).
CAL_EVENT_TYPE_ID=
# Cal.com API v2 base + version pins. Defaults are sane; override only if
# Cal.com changes them. Slots and bookings can pin different versions.
CAL_API_BASE=https://api.cal.com
CAL_API_VERSION_SLOTS=2024-09-04
CAL_API_VERSION_BOOKINGS=2024-08-13
# Default timezone used when the caller doesn't state one.
DEFAULT_TIMEZONE=Asia/Kolkata

# --- Booking backend server ---
# Shared secret Retell sends in an Authorization header to your function URLs,
# so randoms can't drive your calendar. Set the same value in Retell.
BOOKING_WEBHOOK_SECRET=
PORT=8000

# --- Retell (eval harness uses these to drive the live chat agent) ---
RETELL_API_KEY=
RETELL_CHAT_AGENT_ID=
RETELL_API_BASE=https://api.retellai.com

# --- Eval judge (OpenAI-compatible, with automatic primary->backup fallback) ---
# eval/judge.py scores answers grounded/refused/fabricated. Usage is tiny (tens
# of questions) — free tiers cost nothing. Use a judge from a DIFFERENT model
# family than your Retell agent to avoid self-grading bias.
# PRIMARY judge (presets — Groq/Gemini are free):
#   Groq   : JUDGE_BASE_URL=https://api.groq.com/openai/v1                             JUDGE_MODEL=llama-3.3-70b-versatile
#   Gemini : JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/   JUDGE_MODEL=gemini-2.0-flash
#   OpenAI : JUDGE_BASE_URL=https://api.openai.com/v1                                  JUDGE_MODEL=gpt-4o-mini
JUDGE_API_KEY=
JUDGE_BASE_URL=https://api.groq.com/openai/v1
JUDGE_MODEL=llama-3.3-70b-versatile
# BACKUP judge (optional) — used automatically if the primary errors / rate-limits.
#   z.ai   : JUDGE_BACKUP_BASE_URL=https://api.z.ai/api/paas/v4/                        JUDGE_BACKUP_MODEL=glm-4.6
JUDGE_BACKUP_API_KEY=
JUDGE_BACKUP_BASE_URL=https://api.z.ai/api/paas/v4/
JUDGE_BACKUP_MODEL=glm-4.6
